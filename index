script
let appData = [];

 ── NAVIGATION ── 
function switchScreen(name) {
  document.querySelectorAll('.screen').forEach(s = s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b = b.classList.remove('active'));
  document.getElementById('screen' + cap(name)).classList.add('active');
  document.getElementById('nav'    + cap(name)).classList.add('active');
  if (name === 'consulta') renderConsultaState();
}
function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

 ── UPLOAD ── 
const dropZone  = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');

dropZone.addEventListener('dragover',  e = { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () = dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e = {
  e.preventDefault(); dropZone.classList.remove('drag-over');
  if (e.dataTransfer.files[0]) processFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', e = { if (e.target.files[0]) processFile(e.target.files[0]); });

function processFile(file) {
  clearFileError();
  const reader = new FileReader();
  reader.onload = evt = {
    try {
      const wb  = XLSX.read(evt.target.result, { type 'binary' });
      const ws  = wb.Sheets[wb.SheetNames[0]];
      const raw = XLSX.utils.sheet_to_json(ws, { defval '' });
      const norm = raw.map(row = {
        const r = {};
        Object.keys(row).forEach(k = { r[k.trim().toUpperCase()] = String(row[k]).trim(); });
        return r;
      });
      const missing = ['NOME','CPF','SALA','ANDAR'].filter(c = norm.length  0 && norm[0][c] === undefined);
      if (missing.length) {
        showFileError(`Coluna(s) não encontrada(s) strong${missing.join(', ')}strong. Verifique os cabeçalhos da planilha.`);
        return;
      }
      appData = norm;
      dropZone.style.display  = 'none';
      document.getElementById('fileLoaded').style.display = 'block';
      document.getElementById('fileName').textContent = file.name;
      document.getElementById('fileInfo').textContent = `${norm.length} registro(s) carregado(s) com sucesso`;
      document.getElementById('statTotal').textContent   = norm.length;
      document.getElementById('statSalas').textContent   = new Set(norm.map(r = r.SALA)).size;
      document.getElementById('statAndares').textContent = new Set(norm.map(r = r.ANDAR)).size;
      document.getElementById('statsRow').style.display  = 'grid';
      document.getElementById('btnIrConsulta').disabled  = false;
    } catch(e) {
      showFileError('Erro ao ler o arquivo. Certifique-se de que é um strong.xlsx válidostrong.');
    }
  };
  reader.readAsBinaryString(file);
}

function resetFile() {
  appData = [];
  fileInput.value = '';
  dropZone.style.display = 'block';
  document.getElementById('fileLoaded').style.display = 'none';
  document.getElementById('statsRow').style.display   = 'none';
  document.getElementById('btnIrConsulta').disabled   = true;
  clearFileError();
}
function showFileError(msg) {
  const el = document.getElementById('fileError');
  el.style.display = 'block';
  el.innerHTML = `div class=file-error-msg⚠️ ${msg}div`;
}
function clearFileError() {
  const el = document.getElementById('fileError');
  el.style.display = 'none'; el.innerHTML = '';
}

 ── CONSULTA STATE ── 
function renderConsultaState() {
  const has = appData.length  0;
  document.getElementById('searchUI').style.display      = has  'block'  'none';
  document.getElementById('noDataNotice').style.display  = has  'none'   'block';
  clearSearch();
}

 ── CPF MASK ── 
document.getElementById('inputCPF').addEventListener('input', function() {
  let v = this.value.replace(Dg,'').slice(0,11);
  if (v.length  9)      v = v.replace(^(d{3})(d{3})(d{3})(d{0,2})., '$1.$2.$3-$4');
  else if (v.length  6) v = v.replace(^(d{3})(d{3})(d{0,3}),          '$1.$2.$3');
  else if (v.length  3) v = v.replace(^(d{3})(d{0,3}),                  '$1.$2');
  this.value = v;
});
['inputNome','inputCPF'].forEach(id = {
  document.getElementById(id).addEventListener('keydown', e = { if (e.key === 'Enter') doSearch(); });
});

 ── SEARCH ── 
function normalize(s) {
  return s.toLowerCase().normalize('NFD').replace([u0300-u036f]g,'').replace([.-s]g,'');
}

function doSearch() {
  const qNome = document.getElementById('inputNome').value.trim();
  const qCPF  = document.getElementById('inputCPF').value.trim();
  if (!qNome && !qCPF) {
    showResult(`div class=result-errorPreencha o strongNomestrong ou o strongCPFstrong para realizar a busca.div`);
    return;
  }
  const nNome = normalize(qNome), nCPF = normalize(qCPF);
  const matches = appData.filter(row = {
    const rNome = normalize(row.NOME  ''), rCPF = normalize(row.CPF  '');
    if (nNome && nCPF) return rNome.includes(nNome) && rCPF.includes(nCPF);
    if (nNome) return rNome.includes(nNome);
    if (nCPF)  return rCPF.includes(nCPF);
    return false;
  });

  if (matches.length === 0) {
    showResult(`div class=result-error😕 Nenhum resultado encontrado para strong${qNome  qCPF}strong.brVerifique os dados informados e tente novamente.div`);
  } else if (matches.length === 1) {
    const m = matches[0];
    showResult(`
      div class=result-success
        div class=result-name${m.NOME}div
        div class=result-metaCPF ${m.CPF}div
        div class=result-grid
          div class=result-box
            div class=result-box-labelSaladiv
            div class=result-box-value${m.SALA}div
          div
          div class=result-box
            div class=result-box-labelAndardiv
            div class=result-box-value${m.ANDAR}div
          div
        div
      div`);
  } else {
    const rows = matches.map(m = `
      div class=multi-row
        div class=multi-info
          div class=multi-nome${m.NOME}div
          div class=multi-cpf${m.CPF}div
        div
        div class=chips
          span class=chip chip-salaSala ${m.SALA}span
          span class=chip chip-andar${m.ANDAR}º andarspan
        div
      div`).join('');
    showResult(`div class=multi-label${matches.length} resultados encontradosdivdiv class=multi-list${rows}div`);
  }
}

function showResult(html) {
  const el = document.getElementById('result');
  el.innerHTML = html; el.style.display = 'block';
  el.style.animation = 'none'; void el.offsetWidth; el.style.animation = '';
}
function clearSearch() {
  document.getElementById('inputNome').value = '';
  document.getElementById('inputCPF').value  = '';
