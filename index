style
, before, after { box-sizing border-box; margin 0; padding 0; }

root {
  --purple     #4B3FD8;
  --purple-light #6C63FF;
  --purple-bg  rgba(75,63,216,0.08);
  --purple-border rgba(75,63,216,0.18);
  --text       #1a1a2e;
  --muted      #6b7280;
  --light      #9ca3af;
  --bg         #f7f6fb;
  --white      #ffffff;
  --border     #e5e7eb;
  --danger     #ef4444;
  --danger-bg  #fef2f2;
  --success    #10b981;
  --success-bg #f0fdf4;
  --radius     18px;
  --shadow     0 8px 40px rgba(75,63,216,0.10), 0 2px 8px rgba(0,0,0,0.06);
}

html { scroll-behavior smooth; }

body {
  background var(--bg);
  color var(--text);
  font-family 'Inter', sans-serif;
  min-height 100vh;
  display flex;
  flex-direction column;
  align-items center;
  justify-content center;
  padding 40px 16px;
  position relative;
  overflow-x hidden;
}

 ── BLOBS ── 
.blob {
  position fixed;
  border-radius 50%;
  pointer-events none;
  z-index 0;
  filter blur(0);
}
.blob-peach {
  width 280px; height 280px;
  top -60px; right -60px;
  background #f5cba7;
  border-radius 50% 40% 60% 50%;
  opacity 0.7;
}
.blob-pink {
  width 200px; height 200px;
  bottom -40px; left -40px;
  background #f8a7b8;
  border-radius 60% 50% 40% 50%;
  opacity 0.65;
}
.blob-purple-sm {
  width 120px; height 120px;
  bottom 120px; right 60px;
  background #c4b8f5;
  border-radius 50%;
  opacity 0.4;
}

 ── NAV SWITCHER ── 
.nav-switch {
  position fixed;
  top 18px; right 18px;
  z-index 200;
  display flex; gap 4px;
  background var(--white);
  border 1px solid var(--border);
  border-radius 12px;
  padding 4px;
  box-shadow 0 2px 12px rgba(0,0,0,0.08);
}
.nav-btn {
  padding 6px 14px;
  border-radius 9px; border none;
  background transparent;
  color var(--muted);
  font-family 'Inter', sans-serif;
  font-size 12px; font-weight 600;
  cursor pointer; transition all 0.2s;
  white-space nowrap;
}
.nav-btn.active {
  background var(--purple);
  color #fff;
}
.nav-btnhovernot(.active) { color var(--purple); }

 ── SCREENS ── 
.screen {
  position relative; z-index 1;
  display none;
  width 100%;
  flex-direction column;
  align-items center;
  justify-content center;
  min-height 80vh;
}
.screen.active { display flex; }

 ── CARD ── 
.card {
  background var(--white);
  border-radius var(--radius);
  box-shadow var(--shadow);
  width 100%;
  max-width 420px;
  padding 44px 40px 40px;
  position relative;
  overflow hidden;
}
 top colored bar 
.cardbefore {
  content '';
  position absolute;
  top 0; left 0; right 0;
  height 5px;
  background linear-gradient(90deg, var(--purple) 0%, var(--purple-light) 100%);
  border-radius var(--radius) var(--radius) 0 0;
}

 ── LOGO ── 
.logo-wrap {
  text-align center;
  margin-bottom 28px;
}
.logo-dema {
  display inline-flex;
  flex-direction column;
  align-items center;
  line-height 1;
  gap 2px;
}
.logo-text {
  font-size 34px;
  font-weight 700;
  color var(--text);
  letter-spacing -0.04em;
  font-family 'Inter', sans-serif;
}
.logo-text span { color var(--purple); }
.logo-sub {
  font-size 11px;
  font-weight 700;
  letter-spacing 0.22em;
  text-transform uppercase;
  color var(--purple);
}

 ── CARD TITLE ── 
.card-heading {
  text-align center;
  margin-bottom 10px;
}
.card-heading h2 {
  font-size 20px;
  font-weight 700;
  color var(--purple);
  letter-spacing -0.01em;
}
.card-heading p {
  font-size 14px;
  color var(--muted);
  line-height 1.65;
  margin-top 8px;
}
.card-heading p strong { color var(--text); font-weight 600; }

 ── DIVIDER ── 
.divider-or {
  display flex; align-items center; gap 10px;
  color var(--light); font-size 12px; font-weight 500;
  margin 16px 0;
}
.divider-orbefore, .divider-orafter {
  content ''; flex 1; height 1px; background var(--border);
}

 ── INPUTS ── 
.field { margin-bottom 14px; }
.field-label {
  display block;
  font-size 12px; font-weight 600;
  color var(--muted); letter-spacing 0.04em;
  margin-bottom 6px;
}
.field-input {
  width 100%;
  border 1.5px solid var(--border);
  border-radius 10px;
  padding 13px 16px;
  font-family 'Inter', sans-serif;
  font-size 14px; color var(--text);
  background #fafafa;
  outline none;
  transition border-color 0.2s, box-shadow 0.2s, background 0.2s;
}
.field-inputplaceholder { color #b0b7c3; }
.field-inputfocus {
  border-color var(--purple);
  background var(--white);
  box-shadow 0 0 0 4px rgba(75,63,216,0.09);
}

 ── BUTTONS ── 
.btn-purple {
  width 100%; padding 14px;
  background var(--purple);
  color #fff;
  border none; border-radius 10px;
  font-family 'Inter', sans-serif;
  font-size 14px; font-weight 700;
  cursor pointer; letter-spacing 0.02em;
  transition background 0.2s, transform 0.15s, box-shadow 0.2s;
  box-shadow 0 4px 18px rgba(75,63,216,0.28);
}
.btn-purplehover { background #3b31c4; transform translateY(-1px); box-shadow 0 6px 22px rgba(75,63,216,0.35); }
.btn-purpleactive { transform translateY(0); }
.btn-purpledisabled { opacity 0.38; cursor not-allowed; transform none; box-shadow none; }

.btn-outline {
  width 100%; padding 12px;
  background transparent;
  border 1.5px solid var(--border);
  border-radius 10px;
  color var(--muted);
  font-family 'Inter', sans-serif;
  font-size 13px; font-weight 500;
  cursor pointer; margin-top 10px;
  transition all 0.2s;
}
.btn-outlinehover { border-color var(--purple); color var(--purple); }

 ── DROP ZONE ── 
.drop-zone {
  border 2px dashed var(--border);
  border-radius 12px;
  padding 32px 20px;
  text-align center;
  cursor pointer;
  transition all 0.25s;
  position relative;
  background #fafafa;
  margin-bottom 16px;
}
.drop-zonehover, .drop-zone.drag-over {
  border-color var(--purple);
  background var(--purple-bg);
}
.drop-zone input[type=file] {
  position absolute; inset 0; opacity 0; cursor pointer; width 100%; height 100%;
}
.drop-icon { font-size 30px; margin-bottom 10px; }
.drop-text { color var(--muted); font-size 13px; line-height 1.7; }
.drop-text strong { color var(--purple); font-weight 600; }
.drop-sub { font-size 11px; margin-top 4px; color var(--light); }

 ── FILE LOADED ── 
.file-loaded {
  display flex; align-items center; gap 12px;
  background var(--success-bg); border 1px solid #a7f3d0;
  border-radius 10px; padding 12px 16px; margin-bottom 16px;
}
.file-loaded-icon { font-size 20px; flex-shrink 0; }
.file-loaded-name { font-size 13px; font-weight 600; color #065f46; }
.file-loaded-info { font-size 11px; color var(--success); margin-top 2px; }
.file-reset-btn {
  margin-left auto; flex-shrink 0;
  background transparent; border 1px solid #a7f3d0;
  color var(--success); border-radius 7px;
  padding 4px 10px; font-size 11px; font-weight 600;
  cursor pointer; transition all 0.2s;
}
.file-reset-btnhover { background #dcfce7; }

 ── STATS ── 
.stats-row {
  display grid; grid-template-columns repeat(3,1fr); gap 8px; margin-bottom 16px;
}
.stat-box {
  background var(--purple-bg); border 1px solid var(--purple-border);
  border-radius 10px; padding 12px 8px; text-align center;
}
.stat-num { font-size 20px; font-weight 700; color var(--purple); }
.stat-label { font-size 10px; color var(--muted); margin-top 3px; font-weight 500; }

 ── RESULT ── 
#result { margin-top 16px; animation fadeUp 0.3s ease both; }
@keyframes fadeUp {
  from { opacity 0; transform translateY(10px); }
  to   { opacity 1; transform translateY(0); }
}

.result-success {
  background var(--purple-bg);
  border 1.5px solid var(--purple-border);
  border-radius 14px; padding 20px;
  position relative; overflow hidden;
}
.result-successbefore {
  content ''; position absolute; top 0; left 0; right 0; height 3px;
  background linear-gradient(90deg, var(--purple), var(--purple-light));
}
.result-name {
  font-size 16px; font-weight 700; color var(--text); margin-bottom 2px;
}
.result-meta { font-size 12px; color var(--muted); margin-bottom 16px; }
.result-grid { display grid; grid-template-columns 1fr 1fr; gap 10px; }
.result-box {
  background var(--white); border 1px solid var(--border);
  border-radius 10px; padding 14px; text-align center;
  box-shadow 0 2px 8px rgba(75,63,216,0.06);
}
.result-box-label {
  font-size 10px; font-weight 600; letter-spacing 0.1em;
  text-transform uppercase; color var(--muted); margin-bottom 6px;
}
.result-box-value {
  font-size 32px; font-weight 700; color var(--purple); line-height 1;
}

.multi-label {
  font-size 11px; font-weight 600; color var(--muted);
  letter-spacing 0.06em; text-transform uppercase; margin-bottom 8px;
}
.multi-list { display flex; flex-direction column; gap 8px; }
.multi-row {
  display flex; align-items center; gap 10px;
  background #fafafa; border 1px solid var(--border);
  border-radius 10px; padding 12px 14px;
  transition border-color 0.2s;
}
.multi-rowhover { border-color var(--purple); }
.multi-info { flex 1; min-width 0; }
.multi-nome { font-size 13px; font-weight 600; overflow hidden; text-overflow ellipsis; white-space nowrap; }
.multi-cpf  { font-size 11px; color var(--muted); margin-top 2px; }
.chips { display flex; gap 6px; flex-shrink 0; }
.chip {
  font-size 11px; font-weight 700; border-radius 6px; padding 3px 9px; white-space nowrap;
}
.chip-sala  { background var(--purple-bg); color var(--purple); border 1px solid var(--purple-border); }
.chip-andar { background #ede9fe; color #7c3aed; border 1px solid #c4b5fd; }

.result-error {
  background var(--danger-bg); border 1px solid #fecaca;
  border-radius 10px; padding 14px 16px;
  color var(--danger); font-size 13px; line-height 1.6;
}
.result-error strong { font-weight 600; }

 ── NO DATA ── 
.no-data-notice {
  text-align center; padding 10px 0;
}
.no-data-notice .nd-icon { font-size 32px; margin-bottom 10px; }
.no-data-notice p {
  font-size 13px; color var(--muted); line-height 1.7; margin-bottom 16px;
}
.no-data-notice strong { color var(--purple); }

 ── CONTACT FOOTER ── 
.card-footer {
  text-align center; margin-top 20px;
  font-size 12px; color var(--muted); line-height 1.8;
}
.card-footer strong { color var(--text); font-weight 600; }

 ── FILE ERROR ── 
.file-error-msg {
  background var(--danger-bg); border 1px solid #fecaca;
  border-radius 10px; padding 12px 16px;
  color var(--danger); font-size 12.5px; line-height 1.6;
  margin-bottom 14px;
}

@media (max-width 480px) {
  .card { padding 36px 22px 30px; }
  .stats-row { grid-template-columns 1fr 1fr; }
  .stats-row .stat-boxlast-child { grid-column span 2; }
  .chips { flex-direction column; gap 3px; }
}
